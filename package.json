{
  "name": "desafio-automacao-de-testes-mobile-carrefour",
  "version": "1.0.0",
  "description": "Automação de testes mobile para desafio técnico Carrefour",
  "type": "module",
  "scripts": {
    "test": "ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} wdio run config/wdio.android.app.conf.js",
    "android.app": "ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} wdio run config/wdio.android.app.conf.js",
    "ios.app": "wdio run config/wdio.ios.app.conf.js",
    "report": "allure generate reports/allure-results -o reports/allure-report --clean && allure open reports/allure-report",
    "postinstall": "appium driver install uiautomator2@2.34.0 || true && appium driver install xcuitest@5.0.0 || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.4.1",
    "@wdio/appium-service": "^9.4.1",
    "@wdio/cli": "^9.4.1",
    "@wdio/globals": "^9.4.1",
    "@wdio/local-runner": "^9.4.1",
    "@wdio/mocha-framework": "^9.4.1",
    "@wdio/spec-reporter": "^9.4.1",
    "allure-commandline": "^2.32.0",
    "appium": "^2.0.0",
    "appium-uiautomator2-driver": "^2.34.0",
    "appium-xcuitest-driver": "^5.0.0",
    "chai": "^4.5.0"
  }
}
